# dbt MCP environment variables
# -------------------------------------------------------
# Copy this file to .env.dbt in the project root:
#   cp .env.dbt.example .env.dbt
#
# Fill in the absolute paths for your machine.
# .env.dbt is gitignored — never commit it.
# -------------------------------------------------------

# Absolute path to the dbt project folder (where dbt_project.yml lives)
DBT_PROJECT_DIR=/absolute/path/to/diet-analytics-engineer/diet_dbt

# Absolute path to the dbt executable inside your virtual environment
# Run: source venv/bin/activate && which dbt
DBT_PATH=/absolute/path/to/diet-analytics-engineer/venv/bin/dbt
